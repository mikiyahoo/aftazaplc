# ============================================
# DATABASE CONFIGURATION
# ============================================
# Supabase PostgreSQL with PgBouncer (Connection Pooler)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=no-verify&connect_timeout=10"

# Direct Database Connection (without pooler)
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?sslmode=no-verify&connect_timeout=10"

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Public Supabase URL
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"

# Public anon key (for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_[YOUR_ANON_KEY]"

# Server-side service role key (keep secret!)
SUPABASE_SERVICE_ROLE_KEY="sb_secret_[YOUR_SERVICE_ROLE_KEY]"

# ============================================
# NEXTAUTH AUTHENTICATION
# ============================================
# Secret for session encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# Application URL (production)
NEXTAUTH_URL="https://aftaza.com"

# For local development, uncomment:
# NEXTAUTH_URL="http://localhost:3000"

# ============================================
# CLOUDINARY (Image Upload)
# ============================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
# For admin registration email verification
SMTP_HOST="your-smtp-host"
SMTP_PORT=465
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="admin@aftaza.com"

# Optional: Enable SSL/TLS
SMTP_SECURE=true

# ============================================
# APPLICATION SETTINGS
# ============================================
# Environment (development / production)
NODE_ENV="production"

# App URL for admin panel (uncomment when deploying)
# ADMIN_URL="https://admin.aftaza.com"

# ============================================
# SECURITY & RATE LIMITING (Optional)
# ============================================
# Rate limiting settings
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=5    # Max registration attempts

# Password reset token expiry (hours)
RESET_TOKEN_EXPIRY=24

# Verification code expiry (minutes)
VERIFICATION_CODE_EXPIRY=10

# ============================================
# NOTES:
# ============================================
# 1. Admin credentials are NOT stored in .env
#    They are managed in the database 'accounts' table
#
# 2. Database roles:
#    - admin: Full access to all admin features
#    - editor: Content management only
#
# 3. Email verification required for all new accounts
#
# 4. For local development, change NEXTAUTH_URL to:
#    http://localhost:3001
#
# 5. DATABASE_URL uses PgBouncer for connection pooling
#    DIRECT_URL is for direct connections (migrations)
#
# 6. Replace all placeholder values with your actual credentials
#    Never commit real secrets to version control