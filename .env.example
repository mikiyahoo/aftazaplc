# ============================================
# DATABASE - Supabase PostgreSQL
# ============================================
# Your Supabase database connection string
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://your_username:your_password@db.your_project.supabase.co:5432/postgres"

# ============================================
# EMAIL - SMTP for admin verification
# ============================================
# SMTP server configuration for sending verification emails
SMTP_HOST="mail.aftaza.com"
SMTP_PORT="465"
SMTP_USER="admin@aftaza.com"
SMTP_PASS="your_smtp_password"
EMAIL_FROM="admin@aftaza.com"

# ============================================
# AUTH - NextAuth.js configuration
# ============================================
# Secret key for signing cookies and tokens
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_key_here"

# Your application URL (used for callbacks)
NEXTAUTH_URL="http://localhost:3001"

# ============================================
# ADMIN - Default admin credentials
# ============================================
# Default admin email (can be used for registration)
# This email will bypass domain validation
ADMIN_EMAIL="admin@aftaza.com"

# ============================================
# SECURITY - Additional security settings
# ============================================
# Session timeout in minutes (default: 1440 = 24 hours)
SESSION_TIMEOUT_MINUTES="1440"

# Password strength requirements
# Minimum password length
PASSWORD_MIN_LENGTH="8"

# Session warning time in minutes (default: 5)
SESSION_WARNING_MINUTES="5"

# ============================================
# RATE LIMITING - Security configuration
# ============================================
# Registration attempts per IP per hour (default: 5)
REGISTRATION_RATE_LIMIT="5"

# Login attempts per IP per 15 minutes (default: 10)
LOGIN_RATE_LIMIT="10"

# Email verification attempts per email per hour (default: 3)
EMAIL_RATE_LIMIT="3"

# Forgot password attempts per email per hour (default: 3)
FORGOT_PASSWORD_RATE_LIMIT="3"

# Password reset attempts per token per hour (default: 3)
RESET_PASSWORD_RATE_LIMIT="3"

# Block duration after rate limit exceeded in minutes (default: 60)
RATE_LIMIT_BLOCK_DURATION="60"

# ============================================
# FORGOT PASSWORD - Configuration
# ============================================
# Optional: Custom URL for password reset links (defaults to NEXTAUTH_URL)
# NEXT_PUBLIC_SUPABASE_URL="http://localhost:3000"

# ============================================
# NOTE: Admin credentials are NOT stored in .env
# They are managed in the database 'accounts' table
# ============================================