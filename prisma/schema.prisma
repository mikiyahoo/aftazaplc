generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Fix for Supabase SSL issues - add to connection string: sslmode=no-verify

// ============================================
// Table 1 — Accounts (Admin Users)
// ============================================
model Account {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("editor") // admin, editor
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  properties   Property[]

  @@map("accounts")
}

// ============================================
// Table 2 — Properties (Main Table)
// ============================================
model Property {
  pkey         Int      @id @default(autoincrement()) @map("pkey")
  title        String
  slug         String   @unique @map("slug_key")
  price        Float?
  location     String?
  propertyType String?  @map("property_type")
  status       String   @default("active") // active, sold, pending
  bedrooms     Int?
  bathrooms    Int?
  parking      Int?
  area         Float?   // in sq meters
  description  String?  @db.Text
  featured     Boolean  @default(false)
  companyId    String?  @map("company_id")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  company      Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  creator      Account?           @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  images       PropertyImage[]
  inquiries    PropertyInquiry[]

  // Performance indexes
  @@index([status, featured, createdAt])
  @@index([propertyType, status])
  @@index([location])
  @@index([price])
  @@index([companyId])
  @@index([createdBy])
  @@index([createdAt])

  @@map("properties")
}

// ============================================
// Table 3 — Property Images
// ============================================
model PropertyImage {
  id         String   @id @default(cuid())
  propertyId Int      @map("property_id")
  imageUrl   String   @map("image_url")
  isPrimary  Boolean  @default(false) @map("is_primary")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  property   Property @relation(fields: [propertyId], references: [pkey], onDelete: Cascade)

  @@map("property_images")
}

// ============================================
// Table 4 — Companies (Real Estate Companies)
// ============================================
model Company {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  properties Property[]

  @@map("companies")
}

// ============================================
// Table 5 — Testimonials (Success Stories)
// ============================================
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  title     String?
  quote     String   @db.Text
  image     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}

// ============================================
// Table 6 — Property Inquiries (Leads)
// ============================================
model PropertyInquiry {
  id         String   @id @default(cuid())
  propertyId Int?     @map("property_id")
  name       String
  email      String
  phone      String?
  message    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  property   Property? @relation(fields: [propertyId], references: [pkey])

  @@map("property_inquiries")
}

// ============================================
// Legacy Models (kept for backward compatibility)
// ============================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  posts     Post[]
}

model Post {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  excerpt      String
  content      String
  thumbnailUrl String
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
}
